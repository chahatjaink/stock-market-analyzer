# PortfolioGuru Environment Variables
# Copy this file to .env and fill in your values.

GEMINI_API_KEY=your_gemini_api_key_here
RESEND_API_KEY=your_resend_api_key_here
RECIPIENT_EMAIL=your_email@example.com

# Portfolio as a single JSON object.
# Keys are ticker symbols. Each entry needs: name, asset_type ("stock" or "mutual_fund"), market ("IN").
#
# Stock fields:   exchange, qty, avg_price
# MF fields:      amc, category, units, invested_value, xirr (optional)
#
# Example:
# PORTFOLIO_JSON={"HDFCBANK":{"name":"HDFC Bank Ltd","exchange":"NSE","qty":12,"avg_price":727.50,"asset_type":"stock","market":"IN"},"AXIS_LARGECAP":{"name":"Axis Large Cap Fund Growth","amc":"Axis Mutual Fund","category":"Equity - Large Cap","units":2014.235,"invested_value":101994.84,"xirr":"3.27%","asset_type":"mutual_fund","market":"IN"}}
PORTFOLIO_JSON={}
